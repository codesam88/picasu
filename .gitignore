# Ignore all log files at the root level
/*.log

# Prevent uploading development-related scripts and editor configuration files to the main branch
.worktrees/
.vscode/
.opencode/

# User-specific configuration files, added to .gitignore to avoid overwriting during collaboration
backend/config.toml
backend/Rocket.toml
frontend/config.ts
.env

# Ignore build and generated files that should not be version-controlled
frontend/dist
frontend/node_modules
/target/

# `just run`'s dev sandbox (data dir + test galleries, see docs/config.md)
/sandbox/

# playwright test execution environments (generated per run)
.testruns

# Local compose overrides + the bind-mounted volume dirs from compose.yaml
compose.override.yaml
picasu-data/

# Auto-generated by build.rs / just openapi-gen; do not edit or commit.
backend/src/openapi.rs
backend/openapi.json

